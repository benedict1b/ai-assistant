name: naub_ai_new
description: NAUB AI - Smart Assistant for Nigerian Army University Biu
version: 1.0.0+1

environment:
  sdk: ">=3.0.0 <4.0.0"

dependencies:
  flutter:
    sdk: flutter
  google_fonts: ^6.1.0
  sqflite: ^2.3.0
  path_provider: ^2.1.0
  provider: ^6.1.0
  shared_preferences: ^2.2.0
  http: ^1.6.0
  url_launcher: ^6.2.0  # ← ADD THIS LINE

dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^3.0.0

flutter:
  uses-material-design: true
  assets:
    - assets/images/
    - assets/icons/
