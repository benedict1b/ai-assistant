name: naub_ai_new
description: NAUB AI - Smart Assistant for Nigerian Army University Biu
version: 1.0.0+1

environment:
  sdk: ">=3.0.0 <4.0.0"

dependencies:
  flutter:
    sdk: flutter
  
  # =============================================
  # UI & DESIGN
  # =============================================
  google_fonts: ^6.1.0
  
  # =============================================
  # DATABASE & STORAGE
  # =============================================
  sqflite: ^2.3.0
  path_provider: ^2.1.0
  shared_preferences: ^2.2.0
  
  # =============================================
  # STATE MANAGEMENT
  # =============================================
  provider: ^6.1.0
  
  # =============================================
  # API & NETWORK
  # =============================================
  http: ^1.1.0
  connectivity_plus: ^5.0.1
  url_launcher: ^6.2.0
  
  # =============================================
  # XML & FEED PARSING
  # =============================================
  xml: ^6.5.0
  
  # =============================================
  # DOCUMENT UPLOAD & ANALYSIS
  # =============================================
  file_picker: ^8.0.0
  image_picker: ^1.0.4
  google_mlkit_text_recognition: ^0.13.0
  pdf: ^3.10.4
  path: ^1.9.0
  intl: ^0.18.1

dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^3.0.0

flutter:
  uses-material-design: true
  assets:
    - assets/images/
    - assets/icons/